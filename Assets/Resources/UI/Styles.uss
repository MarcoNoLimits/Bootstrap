.glass-panel {
    width: 800px;
    height: 500px;
    background-color: rgba(10, 25, 50, 0.65); /* Deep Blue Translucent */
    border-radius: 20px;
    border-width: 2px;
    border-color: rgba(255, 255, 255, 0.3);
    padding: 20px;
    justify-content: space-between;
}

.row {
    flex-direction: row;
    flex-grow: 1;
}

.center-panel {
    flex-grow: 2;
    padding: 20px;
    align-items: center;
}

.right-panel {
    width: 250px;
    background-color: rgba(0, 0, 0, 0.3);
    border-left-width: 1px;
    border-left-color: rgba(255, 255, 255, 0.1);
    padding: 10px;
}

.header-title {
    font-size: 48px;
    color: rgb(220, 220, 255);
    -unity-font-style: bold;
}

.sub-title {
    font-size: 24px;
    color: rgb(180, 180, 200);
    margin-bottom: 30px;
}

.waveform {
    width: 100%;
    height: 60px;
    background-color: rgba(0, 200, 255, 0.2); /* Placeholder for visualizer */
    margin-bottom: 20px;
    border-radius: 5px;
}

.button-row {
    flex-direction: row;
    width: 100%;
    justify-content: space-around;
    margin-bottom: 40px;
}

.primary-btn {
    width: 150px;
    height: 60px;
    background-color: rgba(0, 120, 215, 0.8);
    color: white;
    font-size: 24px;
    border-radius: 10px;
    border-width: 0;
}

.primary-btn:hover {
    background-color: rgb(0, 150, 255);
}

.nav-item {
    background-color: transparent;
    color: white;
    font-size: 18px;
    border-width: 0;
    align-self: flex-start;
    margin-top: 10px;
}

.bottom-bar {
    height: 60px;
    background-color: rgba(255, 255, 255, 0.1);
    flex-direction: row;
    align-items: center;
    justify-content: center;
    border-radius: 10px;
}